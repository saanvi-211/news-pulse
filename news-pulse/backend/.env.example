PORT=4000
# Path to the SQLite file written by the Python scraper
DB_PATH=../scraper/news_pulse.db
# Full path to Python interpreter (e.g. /usr/bin/python3)
PYTHON_BIN=python3
# Full path to main.py (override if deploying separately)
# SCRAPER_PATH=/app/scraper/main.py
# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:3000
